from sklearn.impute import IterativeImputer
#%%
# 2. 多重插补填补缺失值
imputer = IterativeImputer(random_state=42)
df_imputed = pd.DataFrame(imputer.fit_transform(data), columns=data.columns)
#%%
# 找出原始数据中的缺失位置
missing_mask = data.isnull()

# 按行组织被插补的值
imputed_by_row = {}
for i in range(len(data)):
    row_imputed = []
    for col in data.columns:
        if missing_mask.iloc[i][col] and not pd.isna(df_imputed.iloc[i][col]):
            row_imputed.append((col, df_imputed.iloc[i][col]))
    
    if row_imputed:
        imputed_by_row[i] = row_imputed

# 显示结果
if imputed_by_row:
    print("被插补的位置和值：")
    print("-" * 50)
    for i, row_imputed in imputed_by_row.items():
        print(f"行 {i+1}:")
        for col, value in row_imputed:
            print(f"  {col}: {value}")
else:
    print("没有找到被插补的值（可能原始数据没有缺失值）")
